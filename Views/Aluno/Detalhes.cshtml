@{
    ViewData["Title"] = "Detalhes do Aluno";
}

<h1>Detalhes do Aluno</h1>

<div class="card shadow-sm mt-4">
    <div class="card-body">
        <p><strong>ID:</strong> @ViewBag.Id</p>
        <p><strong>Nome:</strong> @ViewBag.Nome</p>
    </div>
</div>

<p class="mt-3">
    <a asp-controller="Aluno" asp-action="Index" class="btn btn-secondary">Voltar</a>
</p>